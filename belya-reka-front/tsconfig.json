{
  "compilerOptions": {
    "target": "ES2020",
    "typeRoots": ["./node_modules/@types", "./src/fusion/ts/declare/index.d.ts"],
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "src",
    "paths": {
      "assets/*": ["app/assets/*"],
      "pages/*": ["pages/*"],
      "styles/*": ["app/assets/styles/*"],

      "core/*": ["core/*"],
      "components/*": ["components/*"],
      "common/*": ["common/*"],
      "layout/*": ["layout/*"],
      "test/*": ["test/*"],

      "ts/*": ["fusion/ts/*"],
      "helpers/*": ["fusion/helpers/*"],
      "hooks/*": ["fusion/hooks/*"],
      "data/*": ["fusion/data/*"],
      "store/*": ["fusion/store/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
