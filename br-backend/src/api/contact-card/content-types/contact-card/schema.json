{
  "kind": "collectionType",
  "collectionName": "contact_cards",
  "info": {
    "singularName": "contact-card",
    "pluralName": "contact-cards",
    "displayName": "Контакты / Карточки"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "cityName": {
      "type": "string",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::contact-department.contact-department",
      "inversedBy": "contact_cards"
    },
    "contacts": {
      "type": "component",
      "repeatable": true,
      "component": "contacts.contact-item"
    }
  }
}
